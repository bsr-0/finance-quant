# Database — defaults to DuckDB (zero-config, no server needed)
DB_BACKEND=duckdb
DB_PATH=data/market_data.duckdb

# PostgreSQL (only needed if DB_BACKEND=postgresql)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=market_data
# DB_USER=postgres
# DB_PASSWORD=changeme

# FRED API (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Prices source (yahoo, alphavantage, polygon)
PRICES_SOURCE=yahoo
PRICES_API_KEY=

# Polymarket
POLYMARKET_RATE_LIMIT_PER_SEC=5.0

# Alpaca broker (https://app.alpaca.markets/brokerage/dashboard/overview)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Notifications (Slack / Email)
NOTIFY_SLACK_WEBHOOK_URL=
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASSWORD=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=

# Infrastructure
INFRA_MAX_ASYNC_WORKERS=10
INFRA_BATCH_SIZE=1000
INFRA_SNAPSHOT_MAX_WORKERS=4
